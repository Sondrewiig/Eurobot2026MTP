        <!-- 70 mm high, 20 mm thick wall around the granary / black storage area.
             Coordinates are field-frame meters. The wall keeps the robot out of
             the granary instead of relying on planner constraints. Approx area:
             x = 0.60..2.40 m, y = 1.60..2.00 m. -->
        <model name="eurobot_granary_walls">
            <static>true</static>
            <pose>0 0 0 0 0 0</pose>

            <link name="granary_south_wall">
                <pose>1.5 1.59 0.035 0 0 0</pose>
                <collision name="collision">
                    <geometry><box><size>1.84 0.02 0.07</size></box></geometry>
                </collision>
                <visual name="visual">
                    <geometry><box><size>1.84 0.02 0.07</size></box></geometry>
                    <material>
                        <ambient>0.03 0.03 0.03 1</ambient>
                        <diffuse>0.03 0.03 0.03 1</diffuse>
                    </material>
                </visual>
            </link>

            <link name="granary_north_wall">
                <pose>1.5 1.99 0.035 0 0 0</pose>
                <collision name="collision">
                    <geometry><box><size>1.84 0.02 0.07</size></box></geometry>
                </collision>
                <visual name="visual">
                    <geometry><box><size>1.84 0.02 0.07</size></box></geometry>
                    <material>
                        <ambient>0.03 0.03 0.03 1</ambient>
                        <diffuse>0.03 0.03 0.03 1</diffuse>
                    </material>
                </visual>
            </link>

            <link name="granary_west_wall">
                <pose>0.59 1.8 0.035 0 0 0</pose>
                <collision name="collision">

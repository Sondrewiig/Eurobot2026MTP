        <model name="playground_plane">
  <static>true</static>
  <link name="link">

    <collision name="collision">
      <geometry>
        <plane>
          <normal>0 0 1</normal>
          <size>3 2</size>
        </plane>
      </geometry>
    </collision>

    <visual name="visual">
  <geometry>
    <plane>
      <normal>0 0 1</normal>
      <size>3 2</size>
    </plane>
  </geometry>

  <material>
    <ambient>1 1 1 1</ambient>
    <diffuse>1 1 1 1</diffuse>
    <specular>0.1 0.1 0.1 1</specular>
    <pbr>
      <metal>
        <albedo_map>file:///home/sondre/sondre_ws/install/sondre_bot_sim/share/sondre_bot_sim/materials/textures/playground_mat.png</albedo_map>
        <roughness>1.0</roughness>
        <metalness>0.0</metalness>
      </metal>
    </pbr>
  </material>
</visual>

    <pose>1.5 1 0 0 0 0</pose>
  </link>
</model>

        <model name="sondre_bot" canonical_link="chassis" >
          <!-- Initial position of BOT-->
          <pose>0.3 1.9 0 0 0 -1.5707963267949</pose>

<plugin filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">
  <left_joint>left_wheel_joint</left_joint>
  <right_joint>right_wheel_joint</right_joint>
  <wheel_separation>0.20</wheel_separation>
  <wheel_radius>0.03</wheel_radius>
  <topic>/cmd_vel</topic>
  
<min_linear_acceleration>-2</min_linear_acceleration>
<max_linear_acceleration>2</max_linear_acceleration>

<min_linear_velocity>-3</min_linear_velocity>
<max_linear_velocity>3</max_linear_velocity>

<min_angular_acceleration>-3.0</min_angular_acceleration>
<max_angular_acceleration>3.0</max_angular_acceleration>

<min_angular_velocity>-2.0</min_angular_velocity>
<max_angular_velocity>2.0</max_angular_velocity>

</plugin>


<!-- CHASSIS LINK -->

<link name="chassis">
    <visual name="chassis_visual">
        <pose> 0.1 0 0.20 0 0 0 </pose>

        <geometry>
            <box>
                <size>0.25 0.3 0.35</size>
            </box>
        </geometry>

        <material>
  <ambient>0.1 0.1 0.1 1</ambient>
  <diffuse>0.1 0.1 0.1 1</diffuse>
  <specular>0.2 0.2 0.2 1</specular>
</material>

    </visual>
    <collision name="chassis_collision">
        <pose> 0.1 0 0.18 0 0 0 </pose>
        <geometry>
            <box>
                <size>0.25 0.3 0.35</size>
            </box>
        </geometry>
    </collision>
<inertial>
  <pose>0.1 0 0.18 0 0 0</pose>
  <mass>1</mass>
  <inertia>
    <ixx>0.0177083333</ixx>
    <ixy>0</ixy>
    <ixz>0</ixz>
    <iyy>0.0154166667</iyy>
    <iyz>0</iyz>
    <izz>0.0127083333</izz>
  </inertia>
</inertial>
</link>




<!-- LEFT WHEEL LINK -->


<link name="left_wheel">
    <pose> 0.02 0.1 0.03 -1.570796 0 0</pose>
    <visual name="left_wheel_visual">
        <geometry>
            <cylinder>
                <radius>0.03</radius>
                <length>0.03</length>
            </cylinder>
        </geometry>
                <material>
            <ambient>1.0 0.0 0.0 1</ambient>
            <diffuse>1.0 0.0 0.0 1</diffuse>
            <specular>1.0 0.0 0.0 1</specular>
        </material>
    </visual>
    <collision name="left_wheel_collision">
        <geometry>
            <cylinder>
                <radius>0.03</radius>
                <length>0.03</length>
            </cylinder>
        </geometry>
    </collision>
    <inertial>
  <pose>0 0 0 0 0 0</pose>
  <mass>0.05</mass>
  <inertia>
    <ixx>0.000015</ixx>
    <ixy>0</ixy>
    <ixz>0</ixz>
    <iyy>0.000015</iyy>
    <iyz>0</iyz>
    <izz>0.0000225</izz>
  </inertia>
</inertial>
</link>

<joint name="left_wheel_joint" type="revolute">
    <parent> chassis </parent>
    <child> left_wheel </child>
    <axis>
        <xyz>0 0 1</xyz>
        <dynamics>
      <damping>0.2</damping>
    </dynamics>
    </axis>
</joint>


<!-- RIGHT WHEEL LINK -->


<link name="right_wheel">
    <pose> 0.02 -0.1 0.03 1.5707963 0 0 </pose>
    <visual name="right_wheel_visual">
        <geometry>
            <cylinder>
                <radius>0.03</radius>
                <length>0.03</length>
            </cylinder>
        </geometry>
                <material>
            <ambient>1.0 0.0 0.0 1</ambient>
            <diffuse>1.0 0.0 0.0 1</diffuse>
            <specular>1.0 0.0 0.0 1</specular>
        </material>
    </visual>
    <collision name="right_wheel_collision">
        <geometry>
            <cylinder>
                <radius>0.03</radius>
                <length>0.03</length>
            </cylinder>
        </geometry>
    </collision>
    <inertial>
  <pose>0 0 0 0 0 0</pose>
  <mass>0.05</mass>
  <inertia>
    <ixx>0.000015</ixx>
    <ixy>0</ixy>
    <ixz>0</ixz>
    <iyy>0.000015</iyy>
    <iyz>0</iyz>
    <izz>0.0000225</izz>
  </inertia>
</inertial>
</link>

 <joint name="right_wheel_joint" type="revolute"> 
    <parent> chassis </parent>
    <child> right_wheel </child>
    <axis>
        <xyz>0 0 -1</xyz>
        <dynamics>
      <damping>0.2</damping>
    </dynamics>
    </axis>
</joint>


<!-- CASTER WHEEL LINK -->



<link name="caster_wheel">
    <pose> 0.18 0 0.03 0 0 0 </pose>
    <visual name="caster_wheel_visual">
        <geometry>
            <sphere>
                <radius>0.03</radius>
            </sphere>
        </geometry>
        <material>
            <ambient>0.0 1 0.0 1</ambient>
            <diffuse>0.0 1 0.0 1</diffuse>
            <specular>0.0 1 0.0 1</specular>
        </material>
    </visual>
    <collision name="caster_wheel_collision">
  <geometry>
    <sphere>
      <radius>0.03</radius>
    </sphere>
  </geometry>
  <surface>
    <friction>
      <ode>
        <mu>0.001</mu>
        <mu2>0.001</mu2>
      </ode>
    </friction>
  </surface>
</collision>
    <inertial>
  <pose>0 0 0 0 0 0</pose>
  <mass>0.05</mass>
  <inertia>
    <ixx>0.000018</ixx>
    <ixy>0</ixy>
    <ixz>0</ixz>
    <iyy>0.000018</iyy>
    <iyz>0</iyz>
    <izz>0.000018</izz>
  </inertia>
</inertial>
</link>

<joint name="caster_wheel_joint" type="fixed">
    <parent> chassis </parent>
    <child> caster_wheel </child>
</joint>



<!-- add under your model -->

<link name="camera_link">
  <pose>0.22 0 0.28 0 0.78539816 0</pose>

  <visual name="camera_visual">
    <geometry>
      <box>
        <size>0.04 0.14 0.04</size>
      </box>
    </geometry>
    <material>
      <ambient>0.2 0.2 0.8 1</ambient>
      <diffuse>0.2 0.2 0.8 1</diffuse>
    </material>
  </visual>

  <visual name="left_lens">
  <pose>0.016 0.06 0 0 1.57 0</pose>

  <geometry>
    <cylinder>
      <radius>0.01</radius>
      <length>0.01</length>
    </cylinder>
  </geometry>

  <material>
    <ambient>0 0 0 1</ambient>
    <diffuse>0 0 0 1</diffuse>
  </material>
</visual>


<visual name="right_lens">
  <pose>0.016 -0.06 0 0 1.57 0</pose>

  <geometry>
    <cylinder>
      <radius>0.01</radius>
      <length>0.01</length>
    </cylinder>
  </geometry>

</visual>

  <inertial>
    <mass>0.02</mass>
    <inertia>
      <ixx>1e-5</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>1e-5</iyy><iyz>0</iyz>
      <izz>1e-5</izz>
    </inertia>
  </inertial>

  <!-- LEFT CAMERA -->

<sensor name="left_camera" type="camera">
  <pose>0 0.06 0 0 0 0</pose>

  <always_on>true</always_on>
  <update_rate>30</update_rate>
  <visualize>true</visualize>

  <topic>/camera/left/image_raw</topic>

  <camera>
    <horizontal_fov>1.605</horizontal_fov> <!-- 92 deg -->
    <image>
      <width>640</width>
      <height>480</height>
      <format>R8G8B8</format>
    </image>

    <clip>
      <near>0.05</near>
      <far>20</far>
    </clip>
  </camera>
</sensor>


<!-- RIGHT CAMERA -->

<sensor name="right_camera" type="camera">
  <pose>0 -0.06 0 0 0 0</pose>

  <always_on>true</always_on>
  <update_rate>30</update_rate>
  <visualize>true</visualize>

  <topic>/camera/right/image_raw</topic>

  <camera>
    <horizontal_fov>1.605</horizontal_fov>

    <image>
      <width>640</width>
      <height>480</height>
      <format>R8G8B8</format>
    </image>

    <clip>
      <near>0.05</near>
      <far>20</far>
    </clip>
  </camera>
</sensor>

</link>

<joint name="camera_joint" type="fixed">
  <parent>chassis</parent>
  <child>camera_link</child>
</joint>

<!-- ROS optical frame -->
<link name="camera_optical_frame"/>

<joint name="camera_optical_joint" type="fixed">
  <parent>camera_link</parent>
  <child>camera_optical_frame</child>
  <!-- common body->optical rotation -->
  <pose>0 0 0 -1.57079632679 0.78539816 -1.57079632679</pose>
</joint>


</model>



<model name="yellow_ball">
  <pose>1.0 0 0.05 0 0 0</pose>
  <static>false</static>

  <link name="ball_link">
    <inertial>
      <mass>0.1</mass>
      <inertia>
        <ixx>0.0001</ixx>
        <ixy>0</ixy>
        <ixz>0</ixz>
        <iyy>0.0001</iyy>
        <iyz>0</iyz>
        <izz>0.0001</izz>
      </inertia>
    </inertial>

    <collision name="collision">
  <geometry>
    <sphere>
      <radius>0.05</radius>
    </sphere>
  </geometry>

  <surface>
    <friction>
      <ode>
        <mu>10</mu>
        <mu2>10</mu2>
      </ode>
    </friction>

    <bounce>
      <restitution_coefficient>0.0</restitution_coefficient>
    </bounce>

    <contact>
      <ode>
        <kp>100000</kp>
        <kd>10</kd>
      </ode>
    </contact>
  </surface>
</collision>

    <visual name="visual">
      <geometry>
        <sphere>
          <radius>0.05</radius>
        </sphere>
      </geometry>
      <material>
        <ambient>1 1 0 1</ambient>
        <diffuse>1 1 0 1</diffuse>
        <specular>0.3 0.3 0.0 1</specular>
      </material>
    </visual>
  </link>
</model>

    </world>
</sdf>